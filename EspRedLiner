end

local function GetDraws(player)
    if not Cache[player] then
        local bFrame = Instance.new("Frame", DrawLayer)
        bFrame.BackgroundTransparency = 1
        bFrame.Visible = false
        local stroke = Instance.new("UIStroke", bFrame)
        stroke.Thickness = 1
        
        local ti = Instance.new("TextLabel", DrawLayer)
        ti.BackgroundTransparency = 1
        ti.Font = Enum.Font.RobotoMono
        ti.TextSize = 13
        ti.TextStrokeTransparency = 0
        ti.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        ti.Size = UDim2.new(0, 200, 0, 40)
        ti.Visible = false
        
        Cache[player] = {
            Tracer = CreateLine(),
            BoxFrame = bFrame,
            BoxStroke = stroke,
            Skel = {},
            Cross = {CreateLine(), CreateLine()},
            TextInfo = ti
        }
        for i=1, 12 do table.insert(Cache[player].Skel, CreateLine()) end
    end
    return Cache[player]
end

local function RenderLine(frame, p1, p2, color, thickness)
    local dist = (p1 - p2).Magnitude
    if dist < 1 then frame.Visible = false return end
    frame.Size = UDim2.new(0, dist, 0, thickness)
    frame.Position = UDim2.new(0, (p1.X + p2.X) / 2, 0, (p1.Y + p2.Y) / 2)
    frame.Rotation = math.deg(math.atan2(p2.Y - p1.Y, p2.X - p1.X))
    frame.AnchorPoint = Vector2.new(0.5, 0.5)
    frame.BackgroundColor3 = color
    frame.Visible = true
end

local function DrawStrictSkeleton(Camera, char, espSkel, color, rigType)
    local joints = rigType == Enum.HumanoidRigType.R15 and {
        {"Head", "UpperTorso"}, {"UpperTorso", "LowerTorso"},
        {"UpperTorso", "LeftUpperArm"}, {"LeftUpperArm", "LeftLowerArm"},
        {"UpperTorso", "RightUpperArm"}, {"RightUpperArm", "RightLowerArm"},
        {"LowerTorso", "LeftUpperLeg"}, {"LeftUpperLeg", "LeftLowerLeg"},
        {"LowerTorso", "RightUpperLeg"}, {"RightUpperLeg", "RightLowerLeg"}
    } or {
        {"Head", "Torso"}, {"Torso", "Left Arm"}, {"Torso", "Right Arm"},
        {"Torso", "Left Leg"}, {"Torso", "Right Leg"}
    }
    
    local idx = 1
    for _, bone in ipairs(joints) do
        local part1 = char:FindFirstChild(bone[1])
        local part2 = char:FindFirstChild(bone[2])
        if part1 and part2 then
            local p1 = Camera:WorldToViewportPoint(part1.Position)
            local p2 = Camera:WorldToViewportPoint(part2.Position)
            if p1.Z > 0 and p2.Z > 0 then
                RenderLine(espSkel[idx], Vector2.new(p1.X, p1.Y), Vector2.new(p2.X, p2.Y), color, 1)
                idx = idx + 1
            end
        end
    end
    for i = idx, #espSkel do espSkel[i].Visible = false end
end

