            esp.Tracer.Visible = false esp.BoxFrame.Visible = false esp.TextInfo.Visible = false
            for _, v in pairs(esp.Skel) do v.Visible = false end
            for _, v in pairs(esp.Cross) do v.Visible = false end
        end
        return
    end

    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local esp = GetDraws(player)
        local char = player.Character
        local hum = char and char:FindFirstChild("Humanoid")
        
        if not char or not hum or hum.Health <= 0 then
            esp.Tracer.Visible = false esp.BoxFrame.Visible = false esp.TextInfo.Visible = false
            for _, v in pairs(esp.Skel) do v.Visible = false end
            for _, v in pairs(esp.Cross) do v.Visible = false end
            continue
        end

        local color = Settings.NormalColor
        local tracerColor = Settings.NormalColor
        local isTarget = false

        for i = 1, 3 do
            if Settings.Targets[i].Name ~= "" and player.Name == Settings.Targets[i].Name then
                color = Settings.Targets[i].Color tracerColor = Settings.Targets[i].TracerColor isTarget = true break
            end
        end

        local currentHP = 150
        local ro = player:FindFirstChild("ReadOnly")
        if ro and ro:FindFirstChild("health") then currentHP = ro.health.Value end

        if not isTarget and currentHP < Settings.TargetHP then
            color = Settings.TargetHPColor tracerColor = Settings.TargetHPColor
        end

        local rootPart = char:FindFirstChild("HumanoidRootPart")
        local headPart = char:FindFirstChild("Head")
        
        if rootPart and headPart then
            local rootPoint = Camera:WorldToViewportPoint(rootPart.Position)

            -- [!] СТАТИЧНАЯ МАТЕМАТИКА [!] 
            -- Считаем коробку от центра головы до примерного расположения ступней (игнорируя экипировку)
            local topPos = headPart.Position + Vector3.new(0, 0.5, 0)
            local bottomPos = rootPart.Position - Vector3.new(0, 3, 0)
            
            local topPoint = Camera:WorldToViewportPoint(topPos)
            local bottomPoint = Camera:WorldToViewportPoint(bottomPos)

            if rootPoint.Z > 0 and topPoint.Z > 0 and bottomPoint.Z > 0 then
                
                -- Высчитываем высоту и фиксированную ширину (1 к 2)
                local boxHeight = math.abs(bottomPoint.Y - topPoint.Y)
                local boxWidth = boxHeight * 0.5 
                
                local minX = topPoint.X - (boxWidth / 2)
                local minY = topPoint.Y

                if Settings.UseBox then
                    esp.BoxFrame.Position = UDim2.new(0, minX, 0, minY)
                    esp.BoxFrame.Size = UDim2.new(0, boxWidth, 0, boxHeight)
                    esp.BoxStroke.Color = color
                    esp.BoxFrame.Visible = true
                else esp.BoxFrame.Visible = false end

                if Settings.UseTracers then
                    RenderLine(esp.Tracer, Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y), Vector2.new(rootPoint.X, rootPoint.Y), tracerColor, 1)
                else esp.Tracer.Visible = false end

                if Settings.ShowText then
                    esp.TextInfo.Position = UDim2.new(0, minX + (boxWidth/2) - 100, 0, minY - 35)
                    esp.TextInfo.Text = string.format("%s(%s)\n(%d HP)", player.DisplayName, player.Name, currentHP)
                    esp.TextInfo.TextColor3 = Settings.TextColor
                    esp.TextInfo.Visible = true
                else esp.TextInfo.Visible = false end

                if Settings.ShowCross and not isTarget and currentHP < Settings.TargetHP then
                    local cx, cy = topPoint.X, minY + (boxHeight/2)
                    RenderLine(esp.Cross[1], Vector2.new(cx-12, cy-12), Vector2.new(cx+12, cy+12), color, 2)
                    RenderLine(esp.Cross[2], Vector2.new(cx-12, cy+12), Vector2.new(cx+12, cy-12), color, 2)
                else esp.Cross[1].Visible = false esp.Cross[2].Visible = false end

                if Settings.UseSkeleton then
                    DrawStrictSkeleton(Camera, char, esp.Skel, color, hum.RigType)
                else for _, v in pairs(esp.Skel) do v.Visible = false end end

            else
                esp.Tracer.Visible = false esp.BoxFrame.Visible = false esp.TextInfo.Visible = false
                for _, v in pairs(esp.Skel) do v.Visible = false end
                for _, v in pairs(esp.Cross) do v.Visible = false end
            end
        else
            esp.Tracer.Visible = false esp.BoxFrame.Visible = false esp.TextInfo.Visible = false
            for _, v in pairs(esp.Skel) do v.Visible = false end
            for _, v in pairs(esp.Cross) do v.Visible = false end
        end
    end
end)

InputConnection = UserInputService.InputBegan:Connect(function(input, gp)
    if IsBindingKey then
        if input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode ~= Enum.KeyCode.MouseButton1 then
            Settings.ToggleKey = input.KeyCode IsBindingKey = false
            BindKeyBtn.Text = "Menu Key: " .. Settings.ToggleKey.Name
            BindKeyBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        end
        return
    end
    if not gp and input.KeyCode == Settings.ToggleKey then MainFrame.Visible = not MainFrame.Visible end
end)

